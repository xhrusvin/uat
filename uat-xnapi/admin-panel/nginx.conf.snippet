# Add this location block to your existing Nginx server config
# to serve the React admin panel at /xnadmin/

location /xnadmin/ {
    alias /home/dev_xpresshealth/uat/uat-xnapi/admin-panel/dist/;
    try_files $uri $uri/ /xnadmin/index.html;
    index index.html;

    # Cache static assets
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }
}
